---
// Contact section component
---

<section id="contact" class="section" aria-label="Contact and quote request">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Get In Touch</p>
      <h2 class="display-2 silver">Request a quote or speak to our team</h2>
      <p class="prose" style="margin-top:1rem">Tell us about your tonnage, destination, and timing. We respond within one business day.</p>
    </div>

    <div class="two-col contact-grid">
      <div class="reveal">
        <ul class="contact-list">
          <li><span class="contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span><div><div class="contact-label">Address</div><div>22 Bedien Street, Culembeeck AH, Roodepoort, 1724</div></div></li>
          <li><span class="contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg></span><div><div class="contact-label">Phone</div><div><a href="tel:+270000000000">+27 (0) 00 000 0000</a></div></div></li>
          <li><span class="contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span><div><div class="contact-label">Email</div><div><a href="mailto:info@black62.co.za">info@black62.co.za</a></div></div></li>
          <li><span class="contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span><div><div class="contact-label">Registration</div><div>2015/115352/07</div></div></li>
          <li><span class="contact-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg></span><div><div class="contact-label">VAT</div><div>4870279298</div></div></li>
        </ul>
        <div class="map-embed">
          <iframe title="Black62 Commodities Roodepoort office location" src="https://www.google.com/maps?q=22+Bedien+Street,+Culembeeck+AH,+Roodepoort,+1724,+South+Africa&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <form id="enquiry-form" class="enquiry-form reveal delay-1" novalidate>
        <div class="form-grid">
          <div class="field"><label for="name">Full Name <span class="req">*</span></label><input id="name" name="name" type="text" required /></div>
          <div class="field"><label for="company">Company Name <span class="req">*</span></label><input id="company" name="company" type="text" required /></div>
          <div class="field"><label for="email">Email <span class="req">*</span></label><input id="email" name="email" type="email" required /></div>
          <div class="field"><label for="phone">Phone</label><input id="phone" name="phone" type="tel" /></div>
          <div class="field"><label for="commodity">Commodity of Interest</label>
            <select id="commodity" name="commodity">
              <option value="" disabled selected>Select…</option>
              <option>Coal</option><option>Chrome</option><option>Animal Feed</option><option>Logistics</option><option>Other</option>
            </select>
          </div>
          <div class="field"><label for="volume">Estimated Volume / Tonnage</label><input id="volume" name="volume" type="text" /></div>
        </div>
        <div class="field"><label for="message">Message</label><textarea id="message" name="message" rows="5" placeholder="Tell us about your enquiry…"></textarea></div>
        <button type="submit" class="btn btn-primary btn-lg" id="submit-btn">Submit Enquiry</button>
        <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>
