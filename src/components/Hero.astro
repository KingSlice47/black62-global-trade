---
// Hero section component
---

<section class="hero" aria-label="Hero">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-glow" aria-hidden="true"></div>
  <svg class="hero-particles" viewBox="0 0 1000 1000" preserveAspectRatio="none" aria-hidden="true"></svg>
  <div class="container hero-inner">
    <p class="eyebrow fade-in">South African Commodities Trading &amp; Logistics</p>
    <h1 class="display-1 fade-up">
      <span class="silver">Moving Africa's</span><br />
      <span class="silver">Commodities.</span><br />
      <span class="teal">Globally.</span>
    </h1>
    <p class="lead fade-up delay-1">
      Trusted trading and logistics partner in coal, chrome, and animal feed —
      backed by 20+ years of combined industry experience and a specialised
      62-ton abnormal heavy-haul fleet.
    </p>
    <div class="cta-row fade-up delay-2">
      <a href="#contact" class="btn btn-primary btn-lg">Request a Quote</a>
      <a href="/company-profile" class="btn btn-outline btn-lg">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Company Profile
      </a>
    </div>
  </div>
  <a href="#trust" class="scroll-indicator" aria-label="Scroll to next section">
    <span>Scroll</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
  </a>
  <div class="hero-fade" aria-hidden="true"></div>
</section>
